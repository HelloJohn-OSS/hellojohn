# ════════════════════════════════════════════════════════════════════════════════
# HelloJohn — Environment Variables
# Copy to .env and adjust values.
# All env vars are read ONCE at startup by server/config.go (LoadGlobalConfig).
# ════════════════════════════════════════════════════════════════════════════════

# ─── REQUIRED (crypto bootstrap — read directly by wiring.go) ───
# Generate: openssl rand -hex 32
SIGNING_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# Generate: openssl rand -base64 32
SECRETBOX_MASTER_KEY=Z0qYk1Oe7e0rX8NqHkRzL5l1y9Z2Q0E7Vbq3r3b3p0E=

# ─── System ───
APP_ENV=dev                                # dev | staging | prod
BASE_URL=http://localhost:8080             # Backend base URL (issuer, email links)
FS_ROOT=data                               # Control plane filesystem root
CORS_ORIGINS=http://localhost:3000         # CSV of allowed origins

# --- Global DB (Control Plane DB-Centric -- EPIC 008) ---
# Activar modo DB-centric: setear GLOBAL_DB_DSN y reiniciar.
# Sin esta variable, el sistema corre en modo FS-only (sin cambios de comportamiento).
# Las migraciones del schema se aplican automaticamente al arrancar con este DSN.
# Para migrar datos existentes del FS a la DB: ./hellojohn sync-fs-to-db
GLOBAL_DB_DSN=                             # postgres://user:pass@localhost:5432/hellojohn_cp?sslmode=disable
GLOBAL_DB_DRIVER=pg                        # pg | mysql (default: pg)
SYNC_DRY_RUN=false                         # true = simula sync sin escribir (solo para sync-fs-to-db)

# --- Auth / Tokens ---
REFRESH_TTL=720h                           # Refresh token TTL (default 30d)
REGISTER_AUTO_LOGIN=true                   # Auto-login after registration
FS_ADMIN_ENABLE=false                      # Allow FS-admin self-registration

# ─── Session ───
SESSION_SECURE=false                       # Secure cookie flag (auto-inferred from BASE_URL)
SESSION_SAMESITE=Lax                       # Lax | Strict | None
SESSION_DOMAIN=                            # Cookie domain (empty = host only)
SESSION_TTL=24h

# ─── UI / OAuth ───
UI_BASE_URL=http://localhost:3000          # Frontend URL (OAuth consent/login page)
# NEXT_PUBLIC_IS_CLOUD=false              # Set to "true" on cloud deployments to enable billing sidebar nav

# ─── Social Login ───
SOCIAL_LOGIN_CODE_TTL=60s                  # TTL for social login exchange codes
# NOTE: Which providers are enabled is per-tenant (tenant.yaml socialProviders)

# ─── MFA ───
MFA_TOTP_WINDOW=1                          # TOTP validation window ±N (0-3)
MFA_TOTP_ISSUER=HelloJohn                 # Display name in authenticator apps
MFA_SMS_PROVIDER=twilio                    # twilio | vonage
MFA_SMS_PHONE_FIELD=phone                  # User custom field with E.164 phone
MFA_SMS_OTP_LENGTH=6
MFA_SMS_OTP_TTL=5m
MFA_SMS_RATE_LIMIT_HOURLY=5
MFA_SMS_TWILIO_ACCOUNT_SID=
MFA_SMS_TWILIO_AUTH_TOKEN=
MFA_SMS_TWILIO_FROM=
MFA_SMS_VONAGE_API_KEY=
MFA_SMS_VONAGE_API_SECRET=
MFA_SMS_VONAGE_FROM=
MFA_EMAIL_OTP_LENGTH=6
MFA_EMAIL_OTP_TTL=5m
MFA_EMAIL_RATE_LIMIT_HOURLY=5
MFA_EMAIL_SUBJECT=Your verification code
MFA_PREFERRED_FACTOR_FIELD=mfa_preferred_factor
MFA_ADAPTIVE_ENABLED=false
MFA_ADAPTIVE_RULES=ip_change,ua_change,failed_attempts
MFA_ADAPTIVE_FAILURE_THRESHOLD=5
MFA_ADAPTIVE_STATE_TTL=720h
# ─── Admin ───
ADMIN_ENFORCE=0                            # 1 = strict admin role check
ADMIN_SUBS=                                # CSV of emergency admin user IDs

# ─── Feature Flags ───
FEATURE_REFRESH_REUSE_DETECTION=false      # Detect refresh token replay/reuse in /v2/auth/refresh and /oauth2/token refresh flow
FEATURE_SESSION_TOKEN=true                 # Enable /session/token endpoint
FEATURE_CLIENT_PROFILES=true               # Enforce grant compatibility by auth profile
FEATURE_HOST_COOKIE=true                   # Use __Host- cookie prefix when possible

# ─── Misc ───
KEY_ROTATION_GRACE=60                      # Grace period (seconds) after key rotation
SERVICE_VERSION=                           # Shown in /health
SERVICE_COMMIT=                            # Shown in /health

# ─── Audit ───
AUDIT_STDOUT_ENABLED=true                  # Dev visibility. Set false in production.
AUDIT_CONTROLPLANE_LOG_PATH=data/controlplane/audit.log
AUDIT_OVERFLOW_LOG_PATH=data/controlplane/audit-overflow.log

# ─── SMTP Global del Sistema ────────────────────────────────────────────────
# Usado para enviar emails del sistema (invites de admin, notificaciones).
# Diferente al SMTP por-tenant configurado en el panel de administración.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.your-sendgrid-api-key
SMTP_FROM=noreply@hellojohn.io

# ─── Stripe (cloud billing) ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_starter_id_de_stripe
STRIPE_PRICE_PRO=price_pro_id_de_stripe

# ─── Bot Protection — Cloudflare Turnstile ───────────────────────────────────
# Protección anti-bot invisible para login, registro y password reset.
# Obtené las keys en: https://dash.cloudflare.com → Turnstile
# En desarrollo: dejar deshabilitado (BOT_PROTECTION_ENABLED=false).
# Los tenants pueden tener su propia config que overridea la global.
#
BOT_PROTECTION_ENABLED=false
BOT_PROTECTION_PROVIDER=turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
BOT_PROTECT_LOGIN=true
BOT_PROTECT_REGISTRATION=true
BOT_PROTECT_PASSWORD_RESET=false

# ─── URLs de la plataforma (cloud) ───────────────────────────────────────────
APP_URL=https://panel.hellojohn.io         # URL base del panel de administración
CLOUD_API_URL=https://cloud.hellojohn.io   # URL base de la API cloud

# ─── Social Login Admin (solo Cloud — build tag cloud) ───────────────────────
# Permite que los administradores del panel se autentiquen con SSO.
# Las credenciales sociales POR-TENANT se configuran en el panel (tenant.yaml).
ADMIN_GOOGLE_CLIENT_ID=
ADMIN_GOOGLE_CLIENT_SECRET=
ADMIN_GITHUB_CLIENT_ID=
ADMIN_GITHUB_CLIENT_SECRET=
ADMIN_MICROSOFT_CLIENT_ID=
ADMIN_MICROSOFT_CLIENT_SECRET=

# ════════════════════════════════════════════════════════════════════════════════
# Below: per-tenant config (set via admin panel / tenant.yaml, NOT env vars)
#
#   - SMTP (host, port, from, password)
#   - User DB (driver, DSN)
#   - Cache (driver, host, port)
#   - Social providers (which are enabled, Google/GitHub client ID/secret, etc.)
#   - Brand (logo URL, brand color)
#   - User fields, claims config
#
# ════════════════════════════════════════════════════════════════════════════════
